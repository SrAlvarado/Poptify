{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Poptify",
  "version": "0.1.0",
  "identifier": "com.poptify.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:17420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Poptify",
        "width": 520,
        "height": 620,
        "minWidth": 320,
        "minHeight": 200,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval' https://w.soundcloud.com https://connect.soundcloud.com; frame-src https://w.soundcloud.com; connect-src 'self' ipc: http://ipc.localhost https://api-widget.soundcloud.com https://api.soundcloud.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
